# Soracle node config — copy to .env and fill in after deploying the contracts.
SORACLE_RPC_URL=https://soroban-testnet.stellar.org
SORACLE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Contract ids (C...) from `stellar contract deploy`
SORACLE_VERIFIER_ID=
SORACLE_REGISTRY_ID=

# Secret keys (S...). Admin registers vkeys/feeds; publisher publishes values.
# Generate + fund on testnet with: stellar keys generate --fund <name>
SORACLE_ADMIN_SECRET=
SORACLE_PUBLISHER_SECRET=
